{
  "name": "@cubis/foundry",
  "version": "0.3.18",
  "description": "Cubis Foundry CLI for workflow-first AI agent environments",
  "type": "module",
  "bin": {
    "cbx": "bin/cubis.js",
    "cubiskill": "bin/cubis.js",
    "cubis": "bin/cubis.js"
  },
  "files": [
    "bin",
    "Ai Agent Workflow",
    "README.md"
  ],
  "scripts": {
    "start": "node bin/cubis.js",
    "check": "node bin/cubis.js --help",
    "test:attributes": "node scripts/validate-platform-attributes.mjs",
    "test:attributes:strict": "node scripts/validate-platform-attributes.mjs --strict",
    "test:tech-md": "node scripts/test-tech-md-scanner.mjs",
    "test:smoke": "bash scripts/smoke-workflows.sh",
    "test:all": "npm run test:attributes && npm run test:smoke",
    "test:all:strict": "npm run test:attributes:strict && npm run test:smoke",
    "generate:powers": "node \"Ai Agent Workflow/scripts/generate-powers.mjs\"",
    "generate:powers:force": "node \"Ai Agent Workflow/scripts/generate-powers.mjs\" --force",
    "generate:powers:from-skills": "node \"Ai Agent Workflow/scripts/generate-powers.mjs\" --from-skills",
    "generate:powers:sync": "node \"Ai Agent Workflow/scripts/generate-powers.mjs\" --sync-skills --force"
  },
  "engines": {
    "node": ">=18.17"
  },
  "keywords": [
    "cbx",
    "@cubis/foundry",
    "workflow",
    "antigravity",
    "skills",
    "codex",
    "cli"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.8.6",
    "commander": "^14.0.1"
  }
}
