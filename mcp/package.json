{
  "name": "@cubis/foundry-mcp",
  "version": "0.1.0",
  "description": "Cubis Foundry MCP Server – SkillPointer vault, Postman mode, and Stitch profile tools",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cubis-mcp": "dist/index.js"
  },
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec 'tsx src/index.ts -- --transport stdio'",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "scan": "tsx src/index.ts --scan-only",
    "mcp:inspect": "npx @modelcontextprotocol/inspector -- tsx src/index.ts"
  },
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "jsonc-parser": "^3.3.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.1.9",
    "nodemon": "^3.1.0",
    "tsup": "^8.1.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT"
}
