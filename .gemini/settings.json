{
  "mcpServers": {
    "cubis-foundry": {
      "command": "cbx",
      "args": [
        "mcp",
        "serve",
        "--transport",
        "stdio",
        "--scope",
        "project"
      ],
      "env": {}
    },
    "StitchMCP": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://stitch.googleapis.com/mcp",
        "--header",
        "X-Goog-Api-Key: AQ.Ab8RN6LYUKthF2gTQcw5nXAqo4Bv29DmQkRdb0Z0-2pV0HozRw"
      ],
      "env": {}
    }
  }
}
