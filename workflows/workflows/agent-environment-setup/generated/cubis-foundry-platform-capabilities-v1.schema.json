{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cubis Foundry Platform Capabilities",
  "description": "Generated platform capability contracts for supported runtimes.",
  "type": "object",
  "required": [
    "$schema",
    "generatedAt",
    "platforms"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "platforms": {
      "type": "object",
      "additionalProperties": {
        "type": "object"
      }
    }
  },
  "additionalProperties": false
}
